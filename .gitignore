# Secrets
.env
*.env

# OAuth tokens and auth (contain live credentials)
openclaw-docker/core/agents/main/agent/auth-profiles.json
openclaw-docker/core/agents/main/agent/auth.json

# Config backups (auto-generated by openclaw)
openclaw-docker/core/openclaw.json.bak*
openclaw-docker/core/*.bak*
openclaw-docker/cron/*.bak*

# Logs
openclaw-docker/core/logs/
openclaw-docker/core/cron/

# Runtime state (auto-generated)
openclaw-docker/core/devices/
openclaw-docker/core/canvas/
openclaw-docker/core/agents/*/sessions/
openclaw-docker/core/update-check.json
openclaw-docker/core/memory/
openclaw-docker/telegram/
openclaw-docker/chroma/
openclaw-docker/ollama/
openclaw-docker/memory/
openclaw-docker/cron/runs/
openclaw-docker/core/workspace-researcher/

# Obsidian workspace (personal data, synced via iCloud)
openclaw-docker/workspace/memory/

# Scratch
new.txt

# macOS
.DS_Store
**/.DS_Store

# openclaw manages workspace/ as its own git repo — don't double-track it
openclaw-docker/workspace/

# Nested git repos (skills cloned separately)
deployment/skills/agent-browser/

# Homepage dashboard data
openclaw-docker/homepage/

# Home Assistant (personal home automation data)
openclaw-docker/homeassistant/
