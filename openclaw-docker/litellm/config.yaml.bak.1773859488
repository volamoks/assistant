model_list:
- model_name: coding-glm-4.7
  litellm_params:
    model: openai/glm-4.7
    api_base: https://coding-intl.dashscope.aliyuncs.com/v1
    api_key: os.environ/DASHSCOPE_API_KEY
- model_name: coding-glm-5
  litellm_params:
    model: openai/glm-5
    api_base: https://coding-intl.dashscope.aliyuncs.com/v1
    api_key: os.environ/DASHSCOPE_API_KEY
- model_name: coding-kimi-k25
  litellm_params:
    model: openai/kimi-k2.5
    api_base: https://coding-intl.dashscope.aliyuncs.com/v1
    api_key: os.environ/DASHSCOPE_API_KEY
  model_info:
    supports_vision: true
- model_name: coding-minimax-m25
  litellm_params:
    model: openai/MiniMax-M2.5
    api_base: https://coding-intl.dashscope.aliyuncs.com/v1
    api_key: os.environ/DASHSCOPE_API_KEY
  model_info:
    supports_vision: true
- model_name: coding-qwen-3.5-plus
  litellm_params:
    model: openai/qwen3.5-plus
    api_base: https://coding-intl.dashscope.aliyuncs.com/v1
    api_key: os.environ/DASHSCOPE_API_KEY
  model_info:
    supports_vision: true
- model_name: coding-qwen3-coder-next
  litellm_params:
    model: openai/qwen3-coder-next
    api_base: https://coding-intl.dashscope.aliyuncs.com/v1
    api_key: os.environ/DASHSCOPE_API_KEY
- model_name: coding-qwen3-coder-plus
  litellm_params:
    model: openai/qwen3-coder-plus
    api_base: https://coding-intl.dashscope.aliyuncs.com/v1
    api_key: os.environ/DASHSCOPE_API_KEY
- model_name: coding-qwen3-max
  litellm_params:
    model: openai/qwen3-max-2026-01-23
    api_base: https://coding-intl.dashscope.aliyuncs.com/v1
    api_key: os.environ/DASHSCOPE_API_KEY
- model_name: kilo-deepseek
  litellm_params:
    model: openai/deepseek/deepseek-chat
    api_base: https://api.kilo.ai/api/gateway/
    api_key: os.environ/KILOCODE_API_KEY
- model_name: kilo-deepseek-terminus
  litellm_params:
    model: openai/deepseek/deepseek-v3.1-terminus
    api_base: https://api.kilo.ai/api/gateway/
    api_key: os.environ/KILOCODE_API_KEY
- model_name: kilo-minimax
  litellm_params:
    model: openai/minimax/minimax-m2.5:free
    api_base: https://api.kilo.ai/api/gateway/
    api_key: os.environ/KILOCODE_API_KEY
  model_info:
    supports_vision: true
- model_name: kilo-minimax2
  litellm_params:
    model: openai/minimax/minimax-m2.5:free
    api_base: https://api.kilo.ai/api/gateway/
    api_key: os.environ/KILOCODE_API_KEY
  model_info:
    supports_vision: true
- model_name: kilo-nemotron
  litellm_params:
    model: openai/nvidia/nemotron-3-super-120b-a12b-20230311:free
    api_base: https://api.kilo.ai/api/gateway/
    api_key: os.environ/KILOCODE_API_KEY
  model_info:
    supports_reasoning: true
- model_name: local-medium
  litellm_params:
    model: ollama/qwen3.5:9b
    api_base: os.environ/OLLAMA_HOST
- model_name: local-small
  litellm_params:
    model: ollama/qwen2.5-coder:3b
    api_base: os.environ/OLLAMA_HOST
- model_name: minimax-m25
  litellm_params:
    model: openai/MiniMax-M2.5
    api_base: https://api.minimax.io/v1
    api_key: os.environ/MINIMAX_API_KEY
  model_info:
    supports_vision: true
- model_name: minimax-m27
  litellm_params:
    model: openai/MiniMax-M2.7
    api_base: https://api.minimax.io/v1
    api_key: os.environ/MINIMAX_API_KEY
  model_info:
    supports_vision: true
- model_name: nomic-embed-text
  litellm_params:
    model: ollama/nomic-embed-text
    api_base: http://host.docker.internal:11434
    drop_params: true
- model_name: oc-minimax
  litellm_params:
    model: openai/minimax/minimax-m2.5:free
    api_base: https://api.kilo.ai/api/gateway/
    api_key: os.environ/KILOCODE_API_KEY
  model_info:
    supports_vision: true
- model_name: oc-nemotron
  litellm_params:
    model: openai/nemotron-3-super-free
    api_base: https://opencode.ai/zen/v1
    api_key: os.environ/OPENCODE_API_KEY
  model_info:
    supports_reasoning: true
- model_name: qwen-max
  litellm_params:
    model: openai/qwen3-max
    api_base: https://dashscope-intl.aliyuncs.com/compatible-mode/v1
    api_key: os.environ/DASHSCOPE_FREE_API_KEY
- model_name: qwen-plus
  litellm_params:
    model: openai/qwen-plus-2025-07-28
    api_base: https://dashscope-intl.aliyuncs.com/compatible-mode/v1
    api_key: os.environ/DASHSCOPE_FREE_API_KEY
- model_name: qwen-vl-72b
  litellm_params:
    model: openai/qwen2.5-vl-72b-instruct
    api_base: https://dashscope-intl.aliyuncs.com/compatible-mode/v1
    api_key: os.environ/DASHSCOPE_FREE_API_KEY
  model_info:
    supports_vision: true
- model_name: qwen-vl-max
  litellm_params:
    model: openai/qwen-vl-max-2025-04-08
    api_base: https://dashscope-intl.aliyuncs.com/compatible-mode/v1
    api_key: os.environ/DASHSCOPE_FREE_API_KEY
  model_info:
    supports_vision: true
- model_name: qwen-vl-plus
  litellm_params:
    model: openai/qwen-vl-plus-2025-05-07
    api_base: https://dashscope-intl.aliyuncs.com/compatible-mode/v1
    api_key: os.environ/DASHSCOPE_FREE_API_KEY
  model_info:
    supports_vision: true
litellm_settings:
  cache: true
  cache_params:
    type: redis
    host: redis-cache
  request_timeout: 60
  json_logs: true
  success_callback:
  - prometheus
  failure_callback:
  - prometheus
  master_key: os.environ/LITELLM_MASTER_KEY
  pass_through_headers: true
router_settings:
  model_group_alias:
    claw-architect: coding-qwen-3.5-plus
    claw-coder: coding-qwen3-coder-plus
