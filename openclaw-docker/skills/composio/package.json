{
    "name": "@openclaw/composio-skill",
    "version": "1.0.0",
    "description": "Universal tool integration via Composio MCP - easily extensible for 100+ services",
    "type": "module",
    "main": "index.mjs",
    "exports": {
        ".": {
            "import": "./index.mjs"
        },
        "./config": {
            "import": "./config.json"
        }
    },
    "scripts": {
        "test": "node index.mjs list",
        "example:gmail": "node index.mjs run gmail SEND_EMAIL '{\"to\":[\"test@example.com\"],\"subject\":\"Test\",\"body\":\"Hello\"}'",
        "example:query": "node index.mjs query 'What services are available?'",
        "lint": "echo 'No linter configured'"
    },
    "dependencies": {
        "@composio/core": "^0.5.0",
        "@anthropic-ai/claude-agent-sdk": "^0.1.0"
    },
    "devDependencies": {},
    "engines": {
        "node": ">=18.0.0"
    },
    "keywords": [
        "composio",
        "mcp",
        "claude",
        "gmail",
        "notion",
        "slack",
        "github",
        "automation",
        "ai-tools"
    ],
    "author": "OpenClaw",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/openclaw/composio-skill"
    },
    "bugs": {
        "url": "https://github.com/openclaw/composio-skill/issues"
    },
    "homepage": "https://docs.composio.dev"
}