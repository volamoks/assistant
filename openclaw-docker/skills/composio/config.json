{
    "$schema": "./config.schema.json",
    "version": "1.0.0",
    "description": "Composio services configuration - add or remove services as needed",
    "services": {
        "gmail": {
            "enabled": true,
            "description": "Send and manage emails via Gmail",
            "actions": {
                "SEND_EMAIL": {
                    "description": "Send an email to one or more recipients",
                    "requiredParams": [
                        "to",
                        "subject",
                        "body"
                    ],
                    "optionalParams": [
                        "cc",
                        "bcc",
                        "attachments"
                    ]
                },
                "SEARCH_EMAILS": {
                    "description": "Search emails by query",
                    "requiredParams": [
                        "query"
                    ],
                    "optionalParams": [
                        "max_results"
                    ]
                },
                "GET_THREAD": {
                    "description": "Get email thread by ID",
                    "requiredParams": [
                        "thread_id"
                    ],
                    "optionalParams": []
                }
            }
        },
        "notion": {
            "enabled": false,
            "description": "Manage Notion pages and databases",
            "actions": {
                "CREATE_PAGE": {
                    "description": "Create a new Notion page",
                    "requiredParams": [
                        "parent",
                        "properties"
                    ],
                    "optionalParams": [
                        "children",
                        "icon"
                    ]
                },
                "UPDATE_PAGE": {
                    "description": "Update an existing page",
                    "requiredParams": [
                        "page_id",
                        "properties"
                    ],
                    "optionalParams": []
                },
                "QUERY_DATABASE": {
                    "description": "Query a Notion database",
                    "requiredParams": [
                        "database_id"
                    ],
                    "optionalParams": [
                        "filter",
                        "sorts",
                        "page_size"
                    ]
                }
            }
        },
        "slack": {
            "enabled": false,
            "description": "Send messages and manage Slack",
            "actions": {
                "SEND_MESSAGE": {
                    "description": "Send a message to a channel or user",
                    "requiredParams": [
                        "channel",
                        "text"
                    ],
                    "optionalParams": [
                        "thread_ts",
                        "blocks"
                    ]
                },
                "GET_MESSAGES": {
                    "description": "Get messages from a channel",
                    "requiredParams": [
                        "channel"
                    ],
                    "optionalParams": [
                        "limit",
                        "cursor"
                    ]
                },
                "CREATE_CHANNEL": {
                    "description": "Create a new channel",
                    "requiredParams": [
                        "name"
                    ],
                    "optionalParams": [
                        "is_private"
                    ]
                }
            }
        },
        "github": {
            "enabled": false,
            "description": "Manage GitHub issues and repositories",
            "actions": {
                "CREATE_ISSUE": {
                    "description": "Create a new issue",
                    "requiredParams": [
                        "owner",
                        "repo",
                        "title"
                    ],
                    "optionalParams": [
                        "body",
                        "labels",
                        "assignees"
                    ]
                },
                "GET_ISSUE": {
                    "description": "Get issue details",
                    "requiredParams": [
                        "owner",
                        "repo",
                        "issue_number"
                    ],
                    "optionalParams": []
                },
                "LIST_ISSUES": {
                    "description": "List repository issues",
                    "requiredParams": [
                        "owner",
                        "repo"
                    ],
                    "optionalParams": [
                        "state",
                        "labels",
                        "assignee"
                    ]
                }
            }
        },
        "linear": {
            "enabled": false,
            "description": "Linear project management",
            "actions": {
                "CREATE_ISSUE": {
                    "description": "Create a Linear issue",
                    "requiredParams": [
                        "title",
                        "teamId"
                    ],
                    "optionalParams": [
                        "description",
                        "assigneeId",
                        "stateId",
                        "priority"
                    ]
                }
            }
        },
        "trello": {
            "enabled": false,
            "description": "Trello board management",
            "actions": {
                "CREATE_CARD": {
                    "description": "Create a Trello card",
                    "requiredParams": [
                        "idList",
                        "name"
                    ],
                    "optionalParams": [
                        "desc",
                        "due",
                        "labels"
                    ]
                },
                "MOVE_CARD": {
                    "description": "Move card to another list",
                    "requiredParams": [
                        "cardId",
                        "idList"
                    ],
                    "optionalParams": []
                }
            }
        }
    },
    "claude": {
        "enabled": true,
        "model": "claude-sonnet-4-5-20250929",
        "permissionMode": "bypassPermissions"
    },
    "defaults": {
        "externalUserId": "openclaw-user-{{timestamp}}",
        "timeout": 30000,
        "maxRetries": 3
    }
}