{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "litellm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LiteLLM",
      "options": {
        "baseURL": "http://litellm:4000/v1",
        "apiKey": "sk-litellm-openclaw-proxy"
      },
      "models": {
        "claw-opencode": { "name": "OpenCode Free (MiniMax M2.5)" },
        "kilo-minimax-free": { "name": "KiloCode Free (MiniMax M2.5)" },
        "claw-main": { "name": "Premium (MiniMax M2.5)" },
        "local-medium": { "name": "Local (Qwen3.5:9b)" }
      }
    }
  },
  "model": "litellm/claw-opencode",
  "agent": {
    "coder": {
      "description": "Full-stack coding agent. Reads, writes, edits files, runs bash commands.",
      "model": "litellm/claw-opencode",
      "tools": {
        "bash": true,
        "read": true,
        "write": true,
        "edit": true,
        "codesearch": true
      }
    },
    "researcher": {
      "description": "Research and analysis agent with web search.",
      "model": "litellm/kilo-minimax-free",
      "tools": {
        "websearch": true,
        "codesearch": true,
        "read": true
      }
    }
  },
  "default_agent": "coder"
}
