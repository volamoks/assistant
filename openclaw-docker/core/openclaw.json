{
  "meta": {
    "lastTouchedVersion": "2026.2.21",
    "lastTouchedAt": "2026-02-22T05:10:29.053Z"
  },
  "models": {
    "providers": {
      "minimax": {
        "baseUrl": "https://api.minimax.io/anthropic",
        "api": "anthropic-messages",
        "apiKey": "MINIMAX_API_KEY",
        "models": [
          {
            "id": "MiniMax-M2.5",
            "name": "MiniMax M2.5 (direct)",
            "reasoning": true,
            "input": ["text"],
            "cost": { "input": 15, "output": 60, "cacheRead": 2, "cacheWrite": 10 },
            "contextWindow": 200000,
            "maxTokens": 8192
          },
          {
            "id": "MiniMax-M2.5-Lightning",
            "name": "MiniMax M2.5 Lightning (direct)",
            "reasoning": true,
            "input": ["text"],
            "cost": { "input": 15, "output": 60, "cacheRead": 2, "cacheWrite": 10 },
            "contextWindow": 200000,
            "maxTokens": 8192
          }
        ]
      },
      "ollama": {
        "baseUrl": "http://ollama:11434/v1",
        "api": "openai-completions",
        "apiKey": "ollama-local",
        "models": [
          { "id": "llama3.2:1b", "name": "Llama 3.2 1B (local)" },
          { "id": "qwen3:8b", "name": "Qwen3 8B (local)" },
          { "id": "qwen2.5:7b", "name": "Qwen2.5 7B (local)" },
          { "id": "deepseek-r1:14b", "name": "DeepSeek R1 14B (local)", "reasoning": true }
        ]
      },
      "deepseek": {
        "baseUrl": "https://api.deepseek.com/v1",
        "api": "openai-completions",
        "apiKey": "DEEPSEEK_API_KEY",
        "models": [
          {
            "id": "deepseek-chat",
            "name": "DeepSeek Chat (direct)",
            "input": ["text"],
            "cost": { "input": 0.27, "output": 1.1, "cacheRead": 0.07, "cacheWrite": 0.27 },
            "contextWindow": 64000,
            "maxTokens": 8192
          },
          {
            "id": "deepseek-reasoner",
            "name": "DeepSeek R1 (direct)",
            "reasoning": true,
            "input": ["text"],
            "cost": { "input": 0.55, "output": 2.19, "cacheRead": 0.14, "cacheWrite": 0.55 },
            "contextWindow": 64000,
            "maxTokens": 8192
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "openrouter/arcee-ai/trinity-mini:free"
      },
      "models": {
        "google-antigravity/gemini-3-flash": {},
        "google-antigravity/gemini-3-pro": {},
        "google-antigravity/gemini-3-deep-think": {},
        "deepseek/deepseek-chat": { "streaming": false },
        "deepseek/deepseek-reasoner": { "streaming": false },
        "minimax/MiniMax-M2.5": { "streaming": false },
        "minimax/MiniMax-M2.5-Lightning": { "streaming": false },
        "openrouter/deepseek/deepseek-chat": {},
        "openrouter/deepseek/deepseek-r1": {},
        "openrouter/arcee-ai/trinity-mini:free": {},
        "openrouter/arcee-ai/trinity-large-preview:free": {},
        "openrouter/minimax/minimax-01": {},
        "ollama/llama3.2:1b": { "streaming": false },
        "ollama/qwen3:8b": { "streaming": false },
        "ollama/qwen2.5:7b": { "streaming": false },
        "ollama/deepseek-r1:14b": { "streaming": false }
      },
      "compaction": {},
      "timeoutSeconds": 360,
      "subagents": {
        "maxConcurrent": 8,
        "maxSpawnDepth": 2
      }
    },
    "list": [
      {
        "id": "main",
        "heartbeat": {
          "every": "15m",
          "model": "openrouter/arcee-ai/trinity-mini:free",
          "target": "telegram"
        },
        "subagents": {
          "allowAgents": ["coder", "researcher", "analyst"]
        }
      },
      {
        "id": "coder",
        "name": "coder",
        "workspace": "/data/bot/openclaw-docker/workspace",
        "agentDir": "/home/node/.openclaw/agents/coder/agent",
        "model": "deepseek/deepseek-reasoner"
      },
      {
        "id": "researcher",
        "name": "researcher",
        "workspace": "/home/node/.openclaw/workspace-researcher",
        "agentDir": "/home/node/.openclaw/agents/researcher/agent",
        "model": "deepseek/deepseek-chat"
      },
      {
        "id": "analyst",
        "name": "analyst",
        "workspace": "/home/node/.openclaw/workspace-analyst",
        "agentDir": "/home/node/.openclaw/agents/analyst/agent",
        "model": "deepseek/deepseek-reasoner"
      }
    ]
  },
  "tools": {
    "agentToAgent": {
      "enabled": true,
      "allow": ["main", "coder", "researcher", "analyst"]
    }
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },
  "gateway": {
    "mode": "local"
  },
  "plugins": {
    "entries": {
      "telegram": { "enabled": true },
      "google-antigravity-auth": { "enabled": true }
    }
  }
}
